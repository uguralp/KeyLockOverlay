<Window x:Class="KeyLockOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyLockOverlay"
        Width="240" Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        IsHitTestVisible="False"
        Opacity="0">

    <Window.Resources>
        <QuadraticEase x:Key="SmoothEase" EasingMode="EaseOut"/>
    </Window.Resources>

    <!-- Card -->
    <Border x:Name="Card"
            Background="#1C1C1E"
            CornerRadius="14"
            Padding="16,0,18,0">

        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Accent bar -->
            <Border x:Name="AccentBar"
                    Grid.Column="0"
                    Width="4"
                    CornerRadius="2"
                    Margin="0,14,14,14"
                    Background="#4CC9F0"/>

            <!-- Labels -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">

                <TextBlock x:Name="LabelText"
                           Text="CAPS LOCK"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#8E8E93"
                           />

                <TextBlock x:Name="StatusText"
                           Margin="0,2,0,0"
                           Text="ON"
                           FontFamily="Segoe UI"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#4CC9F0"/>
            </StackPanel>

            <!-- Icon -->
            <TextBlock x:Name="IconText"
                       Grid.Column="2"
                       Text="⇪"
                       FontSize="26"
                       VerticalAlignment="Center"
                       Foreground="#4CC9F0"
                       Opacity="0.85"/>
        </Grid>
    </Border>
</Window>
